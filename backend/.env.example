# Backend environment — copy to backend/.env for local dev (NEVER commit the real .env).
# Full variable reference: docs/architecture.md / master guide Appendix A.

# Core
SECRET_KEY=dev-insecure-key-change-me
# DJANGO_SETTINGS_MODULE defaults to config.settings.dev via manage.py

# Database — local dev/tests run on Postgres (matches prod + CI).
# Start it first: docker compose -f docker-compose.dev.yml up -d postgres
DATABASE_URL=postgres://toke:toke@localhost:5433/toke

# Redis (docker-compose maps to localhost:6380)
REDIS_URL=redis://localhost:6380/0

# Meilisearch (local dev)
# MEILISEARCH_URL=http://localhost:7700
# MEILI_MASTER_KEY=devmasterkey

# Celery (defaults to REDIS_URL)
# CELERY_BROKER_URL=redis://localhost:6380/1
# CELERY_TASK_ALWAYS_EAGER=false

# Frontend origins (CORS + links in emails)
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Email — dev uses console; set these for real Resend delivery
# EMAIL_BACKEND=anymail.backends.resend.EmailBackend
# RESEND_API_KEY=re_...
# From address must be on the verified Resend sending domain (mg.tokecosmetics.com)
DEFAULT_FROM_EMAIL="Toke Cosmetics <hello@mg.tokecosmetics.com>"

# Media on S3 (unset = local filesystem in dev). Needed for real uploads.
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# --- Brand ---
# Shown on gateway-hosted checkout pages (Flutterwave, PayPal). BRAND_LOGO_URL must be a
# PUBLIC url the gateway can fetch server-side — once the storefront is deployed, point it
# at the committed logo, e.g. https://tokecosmetics.com/logo.png
# BRAND_NAME=Toké Cosmetics
# BRAND_LOGO_URL=

# --- Checkout ---
# How long checkout holds the stock reservation, in minutes (default 30).
# Since Plan-09b this tunes the CARD gateways only — bank transfer is fixed at 24h on the
# gateway class (BankTransferGateway.reservation_ttl_minutes), because a transfer waits on
# staff working hours and 30 minutes would expire it before anyone reads the statement.
# RESERVATION_TTL_MINUTES=30

# --- Payment gateways (Plan-09) ---
# NOTE: all four are DEACTIVATED at launch (migration payments/0007) — bank transfer is the
# only live method. Their sandbox checkpoint is still outstanding; drive it before you
# reactivate any of them. See docs/architecture.md "Manual payments (Plan-09b)".
# Use TEST-mode keys locally. An unset gateway is a valid state: its adapter raises
# GatewayNotConfigured (503) and `manage.py check` warns (payments.W001). Deactivate the
# gateway per-country in CountryPaymentGateway if you don't intend to offer it.
# Paystack (NG) — the reference we send IS the idempotency key.
# PAYSTACK_SECRET_KEY=sk_test_...
# PAYSTACK_PUBLIC_KEY=pk_test_...
# Flutterwave (NG) — SECRET_HASH is the value you set as the webhook "verif-hash".
# FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
# FLUTTERWAVE_SECRET_HASH=choose-a-long-random-string
# Stripe (intl) — WEBHOOK_SECRET comes from `stripe listen` or the dashboard endpoint.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# PayPal (intl) — WEBHOOK_ID is required to verify webhook signatures.
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=
# Sandbox by default; switch to https://api-m.paypal.com in prod.
# PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# Prod only
# ALLOWED_HOSTS=api.tokecosmetics.com
